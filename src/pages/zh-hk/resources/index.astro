---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';

const competitionCards = [
  {
    name: 'CNAO',
    fullName: '全國中學生天文知識競賽',
    description: '按學年整理的決賽試題。',
    logo: '/assets/logos/cnao.png',
    href: '/zh-hk/resources/cnao/',
    tag: '國家級',
  },
  {
    name: 'IOAA',
    fullName: '國際天文與天體物理奧林匹克競賽',
    description: '按屆次整理理論與數據分析題目。',
    logo: '/assets/logos/ioaa/ioaa.png',
    href: '/zh-hk/resources/ioaa/',
    tag: '國際賽',
  },
  {
    name: 'IAO',
    fullName: '國際天文奧林匹克競賽',
    description: '歷史資料入口（以中文版本為主）。',
    logo: '/assets/logos/iao/iao.png',
    href: '/zh-hk/resources/iao/',
    tag: '歷史檔案',
  },
];

const comingLaterBlocks = [
  {
    eyebrow: '學習筆記',
    title: '筆記資料庫',
    description: '後續將以精選方式公開。',
  },
  {
    eyebrow: '學術論文',
    title: '論文資料庫',
    description: '後續將發布按方向整理的閱讀參考。',
  },
  {
    eyebrow: '程式碼專案',
    title: '程式碼資料庫',
    description: '後續將以精選方式公開腳本與工具。',
  },
  {
    eyebrow: '演示文檔',
    title: '演示資料庫',
    description: '後續將補充公開報告講稿與簡報。',
  },
];
---

<BaseLayout title="資源下載" description="可下載的檔案和資源" locale="zh-hk">
  <section class="section-light content-section resource-hero-shell">
    <div class="container resource-hub">
      <header class="resource-hero">
        <p class="resource-hero-eyebrow">資源庫</p>
        <h1>資源下載</h1>
        <p class="article-description">
          目前已維護資源的精選歸檔頁，優先展示可直接使用的材料。
        </p>
        <nav class="resource-quick-nav" aria-label="資源分類">
          <a href="#competitions">競賽題庫</a>
          <a href="#coming-later">更多內容後續開放</a>
        </nav>
      </header>
    </div>
  </section>

  <section id="competitions" class="section-light content-section resource-major-section resource-major-section-alt">
    <div class="container resource-hub">
      <h2 class="section-title">競賽題庫</h2>
      <p class="section-intro">
        按賽事分組整理的已維護題庫。點擊卡片進入獨立頁並按年份下載。
      </p>

      <div class="resource-major-grid resource-major-grid-3" role="list" aria-label="競賽卡片">
        {competitionCards.map((card) => (
          <article class="resource-entry-card" role="listitem">
            <div class="resource-entry-head">
              <div class="resource-entry-logo-stage">
                <img class="resource-entry-logo" src={card.logo} alt="" aria-hidden="true" loading="lazy" />
              </div>
              <span class="resource-entry-tag">{card.tag}</span>
            </div>
            <h3>{card.name}</h3>
            <p class="resource-entry-fullname">{card.fullName}</p>
            <p>{card.description}</p>
            <a class="resource-entry-link" href={card.href}>
              <span>進入競賽頁面</span>
              <Icon name="chevron.right" />
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="coming-later" class="section-light content-section content-section-compact resource-major-section resource-major-section-base">
    <div class="container resource-hub">
      <h2 class="section-title">更多內容後續開放</h2>
      <p class="section-intro">
        下列欄目會在內容達到可用規模後，以精選方式公開。
      </p>

      <div class="resource-coming-grid" role="list" aria-label="後續開放欄目">
        {comingLaterBlocks.map((block) => (
          <article class="resource-major-card resource-major-card-subtle" role="listitem">
            <p class="resource-category-eyebrow">{block.eyebrow}</p>
            <h3>{block.title}</h3>
            <p>{block.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
