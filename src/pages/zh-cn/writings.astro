---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="写作" description="笔记与随笔" locale="zh-cn">
  <section class="section-light article-page">
    <div class="container article-body">
      <h1>写作</h1>
      <div class="article-description">
        关于物理、数学与相关问题的笔记和随笔。
      </div>

      <div class="article-card">
        <div class="article-meta">2025 年 9 月 23 日 • 力学 / 数学</div>
        <h3>度规概念的初步感悟</h3>
        <p>
          从勾股定理出发，理解度规这一概念如何被视为无穷小距离上的推广。
        </p>
        <a class="button button-link" href="/zh-cn/writing/metric/">阅读文章</a>
      </div>
    </div>
  </section>
</BaseLayout>
