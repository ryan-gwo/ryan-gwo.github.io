---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import InstitutionLogo from '../../components/InstitutionLogo.astro';
---

<BaseLayout title="简历" description="个人简历" locale="zh-cn">
  <section class="section-light cv-document-shell">
    <div class="container cv-document-container">
      <header class="cv-document-header">
        <div class="cv-header-main">
          <h1 class="cv-name">郭雨泽</h1>
          <p class="cv-role"><InstitutionLogo src="/assets/logos/institutions/whu.png">武汉大学</InstitutionLogo>物理学本科生 · 2026 年秋季拟入学 <InstitutionLogo src="/assets/logos/institutions/pku.png">北京大学</InstitutionLogo>天体物理博士</p>
          <p class="cv-focus">研究方向：高能天体物理、引力波、宇宙学与多信使天文学。</p>
        </div>
        <div class="cv-header-links">
          <a class="cv-quick-link" href="mailto:guoyuze@whu.edu.cn"><span class="icon icon-envelope-asset" aria-hidden="true"></span>邮箱</a>
          <a class="cv-quick-link" href="https://github.com/ryan-gwo" target="_blank" rel="noreferrer">GitHub</a>
          <a class="cv-quick-link" href="/assets/pdf/zh-cn/cv_zh.pdf" target="_blank" rel="noreferrer"><Icon name="download" />PDF</a>
          <a class="cv-quick-link" href="/zh-cn/">返回首页</a>
        </div>
      </header>

      <div class="cv-document-layout">
        <main class="cv-main" aria-label="CV 内容">
          <section class="cv-section" aria-labelledby="education-title">
            <h2 id="education-title">教育经历</h2>
            <ol class="cv-timeline">
              <li class="cv-item">
                <div class="cv-item-head">
                  <h3><InstitutionLogo src="/assets/logos/institutions/pku.png">北京大学</InstitutionLogo> · 天体物理学博士（拟）</h3>
                  <p class="cv-item-meta">北京 · 预计 2026 年秋季起</p>
                </div>
                <p>拟在北京大学物理学院天文学系继续开展博士阶段研究。</p>
              </li>
              <li class="cv-item">
                <div class="cv-item-head">
                  <h3><InstitutionLogo src="/assets/logos/institutions/whu.png">武汉大学</InstitutionLogo> · 物理学学士</h3>
                  <p class="cv-item-meta">武汉 · 2022-2026</p>
                </div>
                <p>核心课程：理论力学、电动力学、量子力学、统计物理、数学物理方法、群论、普通天文学、天体物理。</p>
              </li>
            </ol>
          </section>

          <section class="cv-section" aria-labelledby="interests-title">
            <h2 id="interests-title">研究兴趣</h2>
            <ul class="cv-bullets">
              <li>高能天体物理</li>
              <li>引力波天文学</li>
              <li>宇宙学</li>
              <li>多信使天文学</li>
            </ul>
          </section>

          <section class="cv-section" aria-labelledby="research-title">
            <h2 id="research-title">研究经历 / 项目</h2>
            <ol class="cv-timeline">
              <li class="cv-item">
                <div class="cv-item-head">
                  <h3>天文竞赛驱动的系统训练</h3>
                  <p class="cv-item-meta">2019-2021</p>
                </div>
                <p>通过高阶天文竞赛训练建立天文与天体物理基础，重点强化定量建模与观测问题分析能力。</p>
              </li>
              <li class="cv-item">
                <div class="cv-item-head">
                  <h3>本科阶段天体物理方向深化</h3>
                  <p class="cv-item-meta">2022-至今</p>
                </div>
                <p>在武汉大学持续进行天体物理与宇宙学方向学习，围绕引力波及相关课题准备博士阶段研究。</p>
              </li>
            </ol>
          </section>

          <section class="cv-section" aria-labelledby="awards-title">
            <h2 id="awards-title">荣誉与奖项</h2>
            <ul class="cv-awards">
              <li><span class="cv-award-year">2024</span><span class="cv-award-text">国家奖学金，中华人民共和国教育部</span></li>
              <li><span class="cv-award-year">2024</span><span class="cv-award-text">中国科学院国家天文台奖学金，中国科学院国家天文台</span></li>
              <li><span class="cv-award-year">2021</span><span class="cv-award-text">IOAA 金牌，国际天文与天体物理奥林匹克竞赛</span></li>
              <li><span class="cv-award-year">2020</span><span class="cv-award-text">CNAO 金牌，全国中学生天文知识竞赛</span></li>
            </ul>
          </section>

          <section class="cv-section" aria-labelledby="skills-title">
            <h2 id="skills-title">技能</h2>
            <ul class="cv-bullets">
              <li>LaTeX：学术写作、文档排版与参考文献管理</li>
              <li>扎实的数学与物理问题求解训练</li>
            </ul>
          </section>

          <section class="cv-section" aria-labelledby="languages-title">
            <h2 id="languages-title">语言</h2>
            <ul class="cv-bullets">
              <li>中文（母语）</li>
              <li>英语（流利）</li>
            </ul>
          </section>
        </main>

        <aside class="cv-side" aria-label="概要信息">
          <section class="cv-side-card">
            <h2>当前身份</h2>
            <ul class="cv-side-list">
              <li>武汉大学物理学本科生</li>
              <li>拟攻读北京大学天体物理博士</li>
              <li>所在地：中国湖北武汉</li>
            </ul>
          </section>
          <section class="cv-side-card">
            <h2>研究关键词</h2>
            <ul class="cv-side-list">
              <li>Astrophysics</li>
              <li>Gravitational Waves</li>
              <li>Cosmology</li>
              <li>Multi-messenger Astronomy</li>
            </ul>
          </section>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>