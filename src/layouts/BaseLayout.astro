---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import SearchOverlay from '../components/SearchOverlay.astro';
import {
  competitionResources,
  getCompetitionBasePath,
  getEditionPath,
  localePrefixes,
  type ResourceLocale,
} from '../data/competitionResources';

const { title = 'Yuze Guo', description = '', locale = 'en' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const normalizeRoute = (route: string) => {
  if (route === '') {
    return '/';
  }

  if (route === '/') {
    return '/';
  }

  return route.endsWith('/') ? route : `${route}/`;
};
const knownRoutes = new Set<string>();
const staticPageRoutes = Object.keys(import.meta.glob('../pages/**/*.{astro,md,mdx}'))
  .filter((filePath) => !filePath.includes('['))
  .map((filePath) => {
    const route = filePath.replace('../pages', '').replace(/\.(astro|mdx?|md)$/i, '');

    if (route === '/index') {
      return '/';
    }

    return normalizeRoute(route.replace(/\/index$/, ''));
  })
  .filter((route) => !route.endsWith('/publications/'));

for (const currentLocale of Object.keys(localePrefixes) as ResourceLocale[]) {
  for (const competition of Object.values(competitionResources[currentLocale])) {
    knownRoutes.add(normalizeRoute(getCompetitionBasePath(currentLocale, competition.slug)));
    for (const edition of competition.editions) {
      knownRoutes.add(normalizeRoute(getEditionPath(currentLocale, competition.slug, edition)));
    }
  }
}

for (const route of staticPageRoutes) {
  knownRoutes.add(route);
}

const currentPath = normalizeRoute(Astro.url.pathname);
const currentLocalePrefix = currentPath.startsWith('/zh-cn/') || currentPath === '/zh-cn/'
  ? '/zh-cn'
  : currentPath.startsWith('/zh-hk/') || currentPath === '/zh-hk/'
    ? '/zh-hk'
    : '';
const pathWithoutLocale = currentLocalePrefix ? currentPath.slice(currentLocalePrefix.length) || '/' : currentPath;
const localeAlternates = (Object.keys(localePrefixes) as ResourceLocale[])
  .map((targetLocale) => {
    const path = normalizeRoute(`${localePrefixes[targetLocale]}${pathWithoutLocale}`);

    return knownRoutes.has(path)
      ? { locale: targetLocale, href: new URL(path, Astro.site).toString() }
      : undefined;
  })
  .filter((alternate): alternate is { locale: ResourceLocale; href: string } => Boolean(alternate));
const defaultAlternate = localeAlternates.find((alternate) => alternate.locale === 'en');
const hreflangMap = {
  en: 'en',
  'zh-cn': 'zh-CN',
  'zh-hk': 'zh-HK',
} satisfies Record<ResourceLocale, string>;
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION ?? 'edPv1gDwvHyP6q_d4ZonnP1z4Taik4vZ43Tx_5-1xTA';
const bingSiteVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION ?? 'FCAC5D6B1AAEA460C022D6876264FEA5';
const buildDate = new Date();
const currentYear = new Date().getFullYear();
const dateLocale = {
  en: 'en-US',
  'zh-cn': 'zh-CN',
  'zh-hk': 'zh-HK',
}[locale] ?? 'en-US';
const lastUpdatedAt = new Intl.DateTimeFormat(dateLocale, {
  year: 'numeric',
  month: 'long',
}).format(buildDate);
const footerText = {
  en: {
    rights: 'All rights reserved.',
    updated: 'Last updated',
    contact: 'Contact',
    builtWith: 'Built with',
    hostedOn: 'Hosted on',
    sourceCode: 'Source code',
    backToTop: 'Back to top',
  },
  'zh-cn': {
    rights: '保留所有权利。',
    updated: '最近更新',
    contact: '联系',
    builtWith: '使用',
    hostedOn: '托管于',
    sourceCode: '源代码',
    backToTop: '回到顶部',
  },
  'zh-hk': {
    rights: '保留所有權利。',
    updated: '最近更新',
    contact: '聯絡',
    builtWith: '使用',
    hostedOn: '託管於',
    sourceCode: '原始碼',
    backToTop: '回到頂部',
  },
}[locale] ?? {
  rights: 'All rights reserved.',
  updated: 'Last updated',
  contact: 'Contact',
  builtWith: 'Built with',
  hostedOn: 'Hosted on',
  sourceCode: 'Source code',
  backToTop: 'Back to top',
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonical} />
    {localeAlternates.map((alternate) => (
      <link rel="alternate" hreflang={hreflangMap[alternate.locale]} href={alternate.href} />
    ))}
    {defaultAlternate && <link rel="alternate" hreflang="x-default" href={defaultAlternate.href} />}
    <meta name="google-site-verification" content={googleSiteVerification} />
    <meta name="msvalidate.01" content={bingSiteVerification} />
    <link rel="icon" type="image/png" href="/black-hole.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Inter:wght@100..900&family=Noto+Sans+HK:wght@100..900&family=Noto+Sans+SC:wght@100..900&family=Noto+Serif+HK:wght@200..900&family=Noto+Serif+SC:wght@200..900&display=swap" rel="stylesheet">
  </head>
  <body>
    <Nav locale={locale} />
    <SearchOverlay locale={locale} />
    <main>
      <slot />
    </main>
    <button class="back-to-top" type="button" aria-label={footerText.backToTop} title={footerText.backToTop}>
      <span class="back-to-top__icon" aria-hidden="true"></span>
    </button>
    <footer class="site-footer section-light">
      <div class="container footer-inner">
        <p class="footer-copy">© {currentYear} Yuze Guo. {footerText.rights}</p>
        <p class="footer-copy footer-contact">
          {footerText.contact}: <a href="mailto:guoyuze@whu.edu.cn">guoyuze@whu.edu.cn</a>
          {' · '}
          <a href="https://github.com/ryan-gwo" target="_blank" rel="noreferrer">GitHub</a>
        </p>
        <p class="footer-copy footer-updated">{footerText.updated}: {lastUpdatedAt}</p>
        <p class="footer-meta">
          {footerText.builtWith} <a href="https://astro.build" target="_blank" rel="noreferrer">Astro</a>
          {' · '}
          {footerText.hostedOn} <a href="https://pages.github.com" target="_blank" rel="noreferrer">GitHub Pages</a>
          {' · '}
          <a href="https://github.com/ryan-gwo/ryan-gwo.github.io" target="_blank" rel="noreferrer">{footerText.sourceCode}</a>
        </p>
      </div>
    </footer>
    <svg style="position: absolute; width: 0; height: 0; pointer-events: none;" aria-hidden="true">
      <defs>
        <filter id="liquid-refraction" x="0%" y="0%" width="100%" height="100%">
          <feTurbulence type="fractalNoise" baseFrequency="0.015" numOctaves="3" result="noise" />
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="4" xChannelSelector="R" yChannelSelector="G" result="displaced" />
        </filter>
        <filter id="liquid-refraction-subtle" x="0%" y="0%" width="100%" height="100%">
          <feTurbulence type="fractalNoise" baseFrequency="0.02" numOctaves="2" result="noise" />
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="2" xChannelSelector="R" yChannelSelector="G" result="displaced" />
        </filter>
      </defs>
    </svg>
    <script is:inline>
      (() => {
        // Safari & Firefox Fallback Detection
        const ua = navigator.userAgent.toLowerCase();
        const isSafari = ua.includes('safari') && !ua.includes('chrome') && !ua.includes('android');
        const isFirefox = ua.includes('firefox');
        if (isSafari || isFirefox) {
          document.documentElement.classList.add('glass-fallback-active');
        }

        // Dynamic mouse tracking for liquid glass elements
        const updatePointerCoords = (e) => {
          const elements = document.querySelectorAll('[data-liquid-glass]');
          elements.forEach((el) => {
            const rect = el.getBoundingClientRect();
            // Only calculate if hover target is inside viewport for optimization
            if (rect.bottom >= 0 && rect.top <= window.innerHeight) {
              const x = e.clientX - rect.left;
              const y = e.clientY - rect.top;
              el.style.setProperty('--mouse-x', `${x}px`);
              el.style.setProperty('--mouse-y', `${y}px`);
            }
          });
        };

        // Throttle pointer coords tracking for performance
        let frameId;
        document.addEventListener('mousemove', (e) => {
          if (frameId) {
            cancelAnimationFrame(frameId);
          }
          frameId = requestAnimationFrame(() => {
            updatePointerCoords(e);
          });
        }, { passive: true });
      })();
    </script>
    <script is:inline>
      (() => {
        const button = document.querySelector('.back-to-top');
        if (!button) {
          return;
        }

        const showAfter = 220;

        const updateButton = () => {
          const shouldShow = window.scrollY > showAfter;
          button.classList.toggle('is-visible', shouldShow);
        };

        updateButton();
        window.addEventListener('scroll', updateButton, { passive: true });

        button.addEventListener('click', () => {
          const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          window.scrollTo({
            top: 0,
            behavior: reduceMotion ? 'auto' : 'smooth',
          });
        });
      })();
    </script>
  </body>
</html>
