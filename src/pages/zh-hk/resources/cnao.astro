---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CompetitionResourceIndex from '../../../components/CompetitionResourceIndex.astro';
import { getCompetition } from '../../../data/competitionResources';

const competition = getCompetition('zh-hk', 'cnao');
---

<BaseLayout title={competition.title} description={competition.description} locale="zh-hk">
  <section class="section-light article-page">
    <div class="container article-body resource-hub">
      <CompetitionResourceIndex locale="zh-hk" competition={competition} />
    </div>
  </section>
</BaseLayout>
