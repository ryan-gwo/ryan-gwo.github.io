---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';

const years = [
  {
    label: '2024-2025 學年',
    links: [
      { label: '決賽試題', href: '/assets/pdf/zh-hk/CNAO_2025_hk.pdf' },
      { label: '決賽試題（含答案）', href: '/assets/pdf/zh-hk/CNAO_2025_ans_hk.pdf' },
    ],
  },
  {
    label: '2023-2024 學年',
    links: [
      { label: '決賽試題（簡體中文）', href: '/assets/pdf/zh-cn/CNAO_2024.pdf' },
      { label: '決賽試題（含答案，簡體中文）', href: '/assets/pdf/zh-cn/CNAO_2024_ans.pdf' },
    ],
  },
  {
    label: '2022-2023 學年',
    links: [
      { label: '決賽試題（簡體中文）', href: '/assets/pdf/zh-cn/CNAO_2023.pdf' },
      { label: '決賽試題（含答案，簡體中文）', href: '/assets/pdf/zh-cn/CNAO_2023_ans.pdf' },
    ],
  },
  {
    label: '2021-2022 學年',
    links: [
      { label: '決賽試題（簡體中文）', href: '/assets/pdf/zh-cn/CNAO_2022.pdf' },
      { label: '決賽試題影片（簡體中文）', href: '/assets/pdf/zh-cn/CNAO_2022.mp4' },
    ],
  },
  {
    label: '歷史資料',
    links: [
      { label: 'CNAO 2002-2020 決賽與國家集訓隊選拔賽試題及部分解答（簡體中文）', href: '/assets/pdf/zh-cn/CNAO_2002_to_2020.pdf' },
    ],
  },
];
---

<BaseLayout title="CNAO 資源" description="CNAO 資料按年份整理" locale="zh-hk">
  <section class="section-light article-page">
    <div class="container article-body resource-hub">
      <section class="resource-category-panel resource-detail-shell resource-tone-competition">
        <header class="resource-detail-header">
          <div class="resource-detail-main">
            <img class="resource-detail-main-logo" src="/assets/logos/cnao.png" alt="CNAO logo" loading="lazy" />
            <div>
              <p class="resource-category-eyebrow">競賽頁面</p>
              <h1>CNAO 資源</h1>
              <p class="resource-detail-description">按學年整理 CNAO 決賽資料。</p>
            </div>
          </div>
          <a class="resource-back-link" href="/zh-hk/resources/"><Icon name="chevron.left" />返回資源首頁</a>
        </header>

        <div class="resource-year-stack">
          {years.map((year) => (
            <article class="resource-year-card">
              <div class="resource-year-top">
                {year.logo && <img class="resource-year-logo" src={year.logo} alt="" aria-hidden="true" loading="lazy" />}
                <h2 class="resource-year-heading">{year.label}</h2>
              </div>
              <ul class="resource-download-list">
                {year.links.map((link) => (
                  <li>
                    <a class="resource-download-link" href={link.href} target="_blank" rel="noreferrer">
                      <Icon name="download" />
                      <span>{link.label}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
