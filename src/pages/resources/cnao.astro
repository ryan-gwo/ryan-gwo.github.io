---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CompetitionResourceIndex from '../../components/CompetitionResourceIndex.astro';
import { getCompetition } from '../../data/competitionResources';

const competition = getCompetition('en', 'cnao');
---

<BaseLayout title={competition.title} description={competition.description} locale="en">
  <section class="section-light article-page">
    <div class="container article-body resource-hub">
      <CompetitionResourceIndex locale="en" competition={competition} />
    </div>
  </section>
</BaseLayout>
