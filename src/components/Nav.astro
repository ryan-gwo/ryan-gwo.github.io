---
const { locale = 'en' } = Astro.props;

const base = locale === 'en' ? '/' : `/${locale}/`;

const normalizeRoute = (route) => {
  if (route === '/') {
    return '/';
  }

  return route.endsWith('/') ? route : `${route}/`;
};

const pageRoutes = new Set(
  Object.keys(import.meta.glob('../pages/**/*.{astro,md,mdx}', { eager: true })).map((filePath) => {
    const route = filePath.replace('../pages', '').replace(/\.(astro|mdx?|md)$/i, '');

    if (route === '/index') {
      return '/';
    }

    return normalizeRoute(route.replace(/\/index$/, ''));
  }),
);

const localePrefixes = {
  en: '',
  'zh-cn': '/zh-cn',
  'zh-hk': '/zh-hk',
};

const localeHomeLinks = {
  en: '/',
  'zh-cn': '/zh-cn/',
  'zh-hk': '/zh-hk/',
};

const currentPath = normalizeRoute(Astro.url.pathname);

const currentLocalePrefix = currentPath.startsWith('/zh-cn/') || currentPath === '/zh-cn/'
  ? '/zh-cn'
  : currentPath.startsWith('/zh-hk/') || currentPath === '/zh-hk/'
    ? '/zh-hk'
    : '';

const pathWithoutLocale = currentLocalePrefix ? currentPath.slice(currentLocalePrefix.length) || '/' : currentPath;

const localizedPath = (targetLocale) => {
  const targetPath = normalizeRoute(`${localePrefixes[targetLocale]}${pathWithoutLocale}` || '/');

  return pageRoutes.has(targetPath) ? targetPath : localeHomeLinks[targetLocale];
};

const text = {
  en: {
    menu: 'Menu',
    overview: 'Overview',
    writing: 'Writing',
    cv: 'CV',
    resources: 'Downloads',
    github: 'GitHub',
    en: 'EN',
    zhcn: '简',
    zhhk: '繁',
  },
  'zh-cn': {
    menu: '菜单',
    overview: '概览',
    writing: '写作',
    cv: '简历',
    resources: '资源下载',
    github: 'GitHub',
    en: 'EN',
    zhcn: '简',
    zhhk: '繁',
  },
  'zh-hk': {
    menu: '選單',
    overview: '概覽',
    writing: '寫作',
    cv: '履歷',
    resources: '資源下載',
    github: 'GitHub',
    en: 'EN',
    zhcn: '简',
    zhhk: '繁',
  },
}[locale];

const langLinks = {
  en: localizedPath('en'),
  'zh-cn': localizedPath('zh-cn'),
  'zh-hk': localizedPath('zh-hk'),
};

const navItems = [
  { href: `${base}#overview`, label: text.overview },
  { href: `${base}writings/`, label: text.writing },
  { href: `${base}cv/`, label: text.cv },
  { href: `${base}resources/`, label: text.resources },
  { href: 'https://github.com/ryan-gwo', label: text.github, external: true },
];
---

<header class="site-nav">
  <div class="nav-inner">
    <a class="brand" href={base}>Ryan Guo</a>

    <nav class="nav-links">
      {navItems.map((item) => (
        <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noreferrer' : undefined}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="lang-switcher">
      <a class={locale === 'en' ? 'active' : ''} href={langLinks.en}>{text.en}</a>
      <a class={locale === 'zh-cn' ? 'active' : ''} href={langLinks['zh-cn']}>{text.zhcn}</a>
      <a class={locale === 'zh-hk' ? 'active' : ''} href={langLinks['zh-hk']}>{text.zhhk}</a>
    </div>

    <details class="mobile-menu">
      <summary class="mobile-menu-toggle" aria-label={text.menu}>
        <span class="mobile-menu-icon" aria-hidden="true">
          <span></span>
          <span></span>
        </span>
      </summary>

      <div class="mobile-menu-panel">
        <nav class="mobile-menu-links">
          {navItems.map((item) => (
            <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noreferrer' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>

        <div class="mobile-menu-langs">
          <a class={locale === 'en' ? 'active' : ''} href={langLinks.en}>{text.en}</a>
          <a class={locale === 'zh-cn' ? 'active' : ''} href={langLinks['zh-cn']}>{text.zhcn}</a>
          <a class={locale === 'zh-hk' ? 'active' : ''} href={langLinks['zh-hk']}>{text.zhhk}</a>
        </div>
      </div>
    </details>
  </div>
</header>

<script>
  const menu = document.querySelector('.mobile-menu');
  const summary = menu?.querySelector('.mobile-menu-toggle');
  const panel = menu?.querySelector('.mobile-menu-panel');

  if (menu && summary && panel) {
    const CLOSE_MS = 320;
    let isClosing = false;

    const syncBodyState = () => {
      document.body.classList.toggle(
        'mobile-menu-open',
        menu.open || menu.classList.contains('is-closing')
      );
    };

    const openMenu = () => {
      menu.classList.remove('is-closing');
      menu.open = true;
      summary.setAttribute('aria-expanded', 'true');
      syncBodyState();
    };

    const closeMenu = () => {
      if (!menu.open || isClosing) return;
      isClosing = true;
      menu.classList.add('is-closing');
      summary.setAttribute('aria-expanded', 'false');
      syncBodyState();

      window.setTimeout(() => {
        menu.open = false;
        menu.classList.remove('is-closing');
        isClosing = false;
        syncBodyState();
      }, CLOSE_MS);
    };

    summary.addEventListener('click', (event) => {
      if (menu.open) {
        event.preventDefault();
        closeMenu();
      } else {
        event.preventDefault();
        openMenu();
      }
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        closeMenu();
      });
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeMenu();
      }
    });

    summary.setAttribute('aria-expanded', menu.open ? 'true' : 'false');
    syncBodyState();
  }
</script>