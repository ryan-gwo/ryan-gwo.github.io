---
const { locale = 'en' } = Astro.props;

const base = locale === 'en' ? '/' : `/${locale}/`;

const text = {
  en: {
    overview: 'Overview',
    writing: 'Writing',
    cv: 'CV',
    resources: 'Downloads',
    github: 'GitHub',
    en: 'EN',
    zhcn: '简',
    zhhk: '繁',
  },
  'zh-cn': {
    overview: '概览',
    writing: '写作',
    cv: '简历',
    resources: '资源下载',
    github: 'GitHub',
    en: 'EN',
    zhcn: '简',
    zhhk: '繁',
  },
  'zh-hk': {
    overview: '概覽',
    writing: '寫作',
    cv: '履歷',
    resources: '資源下載',
    github: 'GitHub',
    en: 'EN',
    zhcn: '简',
    zhhk: '繁',
  },
}[locale];

const langLinks = {
  en: '/',
  'zh-cn': '/zh-cn/',
  'zh-hk': '/zh-hk/',
};
---

<header class="site-nav">
  <div class="nav-inner">
    <a class="brand" href={base}>Ryan Guo</a>

    <nav class="nav-links">
      <a href={`${base}#overview`}>{text.overview}</a>
      <a href={`${base}#writing`}>{text.writing}</a>
      <a href={`${base}cv/`}>{text.cv}</a>
      <a href={`${base}resources/`}>{text.resources}</a>
      <a href="https://github.com/ryan-gwo" target="_blank" rel="noreferrer">{text.github}</a>
    </nav>

    <div class="lang-switcher">
      <a class={locale === 'en' ? 'active' : ''} href={langLinks.en}>{text.en}</a>
      <a class={locale === 'zh-cn' ? 'active' : ''} href={langLinks['zh-cn']}>{text.zhcn}</a>
      <a class={locale === 'zh-hk' ? 'active' : ''} href={langLinks['zh-hk']}>{text.zhhk}</a>
    </div>
  </div>
</header>