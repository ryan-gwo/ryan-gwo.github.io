---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

const { title = 'Ryan Guo', description = '', locale = 'en' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const bingSiteVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION;
const currentYear = new Date().getFullYear();
const footerText = {
  en: {
    rights: 'All rights reserved.',
    builtWith: 'Built with',
    hostedOn: 'Hosted on',
    sourceCode: 'Source code',
  },
  'zh-cn': {
    rights: '保留所有权利。',
    builtWith: '使用',
    hostedOn: '托管于',
    sourceCode: '源代码',
  },
  'zh-hk': {
    rights: '保留所有權利。',
    builtWith: '使用',
    hostedOn: '託管於',
    sourceCode: '原始碼',
  },
}[locale] ?? {
  rights: 'All rights reserved.',
  builtWith: 'Built with',
  hostedOn: 'Hosted on',
  sourceCode: 'Source code',
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonical} />
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    {bingSiteVerification && <meta name="msvalidate.01" content={bingSiteVerification} />}
    <link rel="icon" type="image/png" href="/black-hole.png" />
  </head>
  <body>
    <Nav locale={locale} />
    <main>
      <slot />
    </main>
    <footer class="site-footer section-light">
      <div class="container footer-inner">
        <p class="footer-copy">© {currentYear} Yuze Guo. {footerText.rights}</p>
        <p class="footer-meta">
          {footerText.builtWith} <a href="https://astro.build" target="_blank" rel="noreferrer">Astro</a>
          {' · '}
          {footerText.hostedOn} <a href="https://pages.github.com" target="_blank" rel="noreferrer">GitHub Pages</a>
          {' · '}
          <a href="https://github.com/ryan-gwo/ryan-gwo.github.io" target="_blank" rel="noreferrer">{footerText.sourceCode}</a>
        </p>
      </div>
    </footer>
  </body>
</html>