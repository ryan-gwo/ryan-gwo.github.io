---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

const { title = 'Ryan Guo', description = '', locale = 'en' } = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <Nav locale={locale} />
    <main>
      <slot />
    </main>
  </body>
</html>