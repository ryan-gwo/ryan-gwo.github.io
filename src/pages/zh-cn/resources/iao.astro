---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';

const years = [
  {
    label: '2021 年（IRAO）',
    logo: '/assets/logos/iao/irao2021.png',
    links: [
      { label: '理论试题', href: '/assets/pdf/zh-cn/IAO_2021_Theory.pdf' },
    ],
  },
  {
    label: '历史资料',
    logo: '/assets/logos/iao/iao.png',
    links: [
      { label: 'IAO 1996-2021 部分试题集', href: '/assets/pdf/zh-cn/IAO_1996_to_2021_zh.pdf' },
    ],
  },
];
---

<BaseLayout title="IAO 资源" description="IAO 资料按年份整理" locale="zh-cn">
  <section class="section-light article-page">
    <div class="container article-body resource-hub">
      <section class="resource-category-panel resource-detail-shell resource-tone-competition">
        <header class="resource-detail-header">
          <div class="resource-detail-main">
            <img class="resource-detail-main-logo" src="/assets/logos/iao/iao.png" alt="IAO logo" loading="lazy" />
            <div>
              <p class="resource-category-eyebrow">竞赛页面</p>
              <h1>IAO 资源</h1>
              <p class="resource-detail-description">收录可用的 IAO 试题与历史整理资料。</p>
            </div>
          </div>
          <a class="resource-back-link" href="/zh-cn/resources/"><Icon name="chevron.left" />返回资源首页</a>
        </header>

        <div class="resource-year-stack">
          {years.map((year) => (
            <article class="resource-year-card">
              <div class="resource-year-top">
                <img class="resource-year-logo" src={year.logo} alt="" aria-hidden="true" loading="lazy" />
                <h2 class="resource-year-heading">{year.label}</h2>
              </div>
              <ul class="resource-download-list">
                {year.links.map((link) => (
                  <li>
                    <a class="resource-download-link" href={link.href} target="_blank" rel="noreferrer">
                      <Icon name="download" />
                      <span>{link.label}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
