---
import Icon from './Icon.astro';

const { locale = 'en' } = Astro.props;

const base = locale === 'en' ? '/' : `/${locale}/`;

const normalizeRoute = (route) => {
  if (route === '/') {
    return '/';
  }

  return route.endsWith('/') ? route : `${route}/`;
};

const pageRoutes = new Set(
  Object.keys(import.meta.glob('../pages/**/*.{astro,md,mdx}', { eager: true })).map((filePath) => {
    const route = filePath.replace('../pages', '').replace(/\.(astro|mdx?|md)$/i, '');

    if (route === '/index') {
      return '/';
    }

    return normalizeRoute(route.replace(/\/index$/, ''));
  }),
);

const localePrefixes = {
  en: '',
  'zh-cn': '/zh-cn',
  'zh-hk': '/zh-hk',
};

const localeHomeLinks = {
  en: '/',
  'zh-cn': '/zh-cn/',
  'zh-hk': '/zh-hk/',
};

const currentPath = normalizeRoute(Astro.url.pathname);

const currentLocalePrefix = currentPath.startsWith('/zh-cn/') || currentPath === '/zh-cn/'
  ? '/zh-cn'
  : currentPath.startsWith('/zh-hk/') || currentPath === '/zh-hk/'
    ? '/zh-hk'
    : '';

const pathWithoutLocale = currentLocalePrefix ? currentPath.slice(currentLocalePrefix.length) || '/' : currentPath;

const localizedPath = (targetLocale) => {
  const targetPath = normalizeRoute(`${localePrefixes[targetLocale]}${pathWithoutLocale}` || '/');

  return pageRoutes.has(targetPath) ? targetPath : localeHomeLinks[targetLocale];
};

const text = {
  en: {
    menu: 'Menu',
    home: 'Home',
    research: 'Research',
    writing: 'Writing',
    cv: 'CV',
    interests: 'Interests',
    resources: 'Resources',
    en: 'EN',
    zhcn: '简',
    zhhk: '繁',
    theme: 'Theme',
    themeLight: 'Light',
    themeDark: 'Dark',
    themeSystem: 'System',
    search: 'Search',
  },
  'zh-cn': {
    menu: '菜单',
    home: '首页',
    research: '研究',
    writing: '写作',
    cv: '简历',
    interests: '兴趣',
    resources: '资源库',
    en: 'EN',
    zhcn: '简',
    zhhk: '繁',
    theme: '主题',
    themeLight: '浅色',
    themeDark: '深色',
    themeSystem: '系统',
    search: '搜索',
  },
  'zh-hk': {
    menu: '選單',
    home: '首頁',
    research: '研究',
    writing: '寫作',
    cv: '履歷',
    interests: '興趣',
    resources: '資源庫',
    en: 'EN',
    zhcn: '简',
    zhhk: '繁',
    theme: '主題',
    themeLight: '淺色',
    themeDark: '深色',
    themeSystem: '系統',
    search: '搜尋',
  },
}[locale];

const langLinks = {
  en: localizedPath('en'),
  'zh-cn': localizedPath('zh-cn'),
  'zh-hk': localizedPath('zh-hk'),
};

const navItems = [
  { href: `${base}`, label: text.home },
  { href: `${base}research/`, label: text.research },
  { href: `${base}writings/`, label: text.writing },
  { href: `${base}cv/`, label: text.cv },
  { href: `${base}interests/`, label: text.interests },
  { href: `${base}resources/`, label: text.resources },
];

const themeOptions = [
  { value: 'light', label: text.themeLight, icon: 'sun' },
  { value: 'dark', label: text.themeDark, icon: 'moon' },
  { value: 'system', label: text.themeSystem, icon: 'monitor' },
];
---

<header class="site-nav">
  <div class="nav-inner">
    <a class="brand" href={base}>Yuze Guo</a>

    <nav class="nav-links">
      {navItems.map((item) => (
        <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noreferrer' : undefined}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="nav-actions">
      <div class="theme-switcher liquid-glass" role="group" aria-label={text.theme}>
        {themeOptions.map((option) => (
          <button
            class="theme-option"
            type="button"
            data-theme-option={option.value}
            aria-pressed="false"
            aria-label={option.label}
            title={option.label}
          >
            <Icon name={option.icon} />
          </button>
        ))}
      </div>

      <button class="nav-search-trigger liquid-glass" type="button" data-search-open aria-haspopup="dialog" aria-controls="site-search-overlay" aria-label={text.search} title={text.search}>
        <Icon name="search" />
      </button>

      <div class="lang-switcher">
        <a class={locale === 'en' ? 'active' : ''} href={langLinks.en}>{text.en}</a>
        <a class={locale === 'zh-cn' ? 'active' : ''} href={langLinks['zh-cn']}>{text.zhcn}</a>
        <a class={locale === 'zh-hk' ? 'active' : ''} href={langLinks['zh-hk']}>{text.zhhk}</a>
      </div>
    </div>

    <details class="mobile-menu">
      <summary class="mobile-menu-toggle" aria-label={text.menu}>
        <span class="mobile-menu-icon" aria-hidden="true">
          <span></span>
          <span></span>
        </span>
      </summary>

      <div class="mobile-menu-panel liquid-glass-strong">
        <div class="mobile-menu-tools">
          <div class="theme-switcher theme-switcher--mobile liquid-glass" role="group" aria-label={text.theme}>
            {themeOptions.map((option) => (
              <button
                class="theme-option"
                type="button"
                data-theme-option={option.value}
                aria-pressed="false"
                aria-label={option.label}
                title={option.label}
              >
                <Icon name={option.icon} />
                <span>{option.label}</span>
              </button>
            ))}
          </div>

          <button class="nav-search-trigger nav-search-trigger--mobile liquid-glass" type="button" data-search-open aria-haspopup="dialog" aria-controls="site-search-overlay" aria-label={text.search}>
            <Icon name="search" />
            <span>{text.search}</span>
          </button>
        </div>

        <nav class="mobile-menu-links">
          {navItems.map((item) => (
            <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noreferrer' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>

        <div class="mobile-menu-langs">
          <a class={locale === 'en' ? 'active' : ''} href={langLinks.en}>{text.en}</a>
          <a class={locale === 'zh-cn' ? 'active' : ''} href={langLinks['zh-cn']}>{text.zhcn}</a>
          <a class={locale === 'zh-hk' ? 'active' : ''} href={langLinks['zh-hk']}>{text.zhhk}</a>
        </div>
      </div>
    </details>
  </div>
</header>

<script>
  const menu = document.querySelector('.mobile-menu');
  const summary = menu?.querySelector('.mobile-menu-toggle');
  const panel = menu?.querySelector('.mobile-menu-panel');

  if (menu && summary && panel) {
    const CLOSE_MS = 320;
    let isClosing = false;

    const syncBodyState = () => {
      document.body.classList.toggle(
        'mobile-menu-open',
        menu.open || menu.classList.contains('is-closing')
      );
    };

    const openMenu = () => {
      menu.classList.remove('is-closing');
      menu.open = true;
      summary.setAttribute('aria-expanded', 'true');
      syncBodyState();
    };

    const closeMenu = () => {
      if (!menu.open || isClosing) return;
      isClosing = true;
      menu.classList.add('is-closing');
      summary.setAttribute('aria-expanded', 'false');
      syncBodyState();

      window.setTimeout(() => {
        menu.open = false;
        menu.classList.remove('is-closing');
        isClosing = false;
        syncBodyState();
      }, CLOSE_MS);
    };

    summary.addEventListener('click', (event) => {
      if (menu.open) {
        event.preventDefault();
        closeMenu();
      } else {
        event.preventDefault();
        openMenu();
      }
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        closeMenu();
      });
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeMenu();
      }
    });

    window.addEventListener('site-search:open', () => {
      closeMenu();
    });

    summary.setAttribute('aria-expanded', menu.open ? 'true' : 'false');
    syncBodyState();
  }
</script>

<script>
  const themeStorageKey = 'site-theme-preference';
  const themeButtons = Array.from(document.querySelectorAll('[data-theme-option]'));
  const themeMedia = window.matchMedia('(prefers-color-scheme: dark)');
  const themeMeta = document.querySelector('#theme-color-meta');
  const validThemes = new Set(['light', 'dark', 'system']);

  const getThemePreference = () => {
    try {
      const storedPreference = window.localStorage.getItem(themeStorageKey);
      return validThemes.has(storedPreference) ? storedPreference : 'system';
    } catch {
      return 'system';
    }
  };

  const resolveTheme = (preference) => preference === 'system'
    ? (themeMedia.matches ? 'dark' : 'light')
    : preference;

  const syncThemeButtons = (preference) => {
    themeButtons.forEach((button) => {
      const isActive = button.dataset.themeOption === preference;
      button.classList.toggle('is-active', isActive);
      button.setAttribute('aria-pressed', String(isActive));
    });
  };

  const applyThemePreference = (preference) => {
    const normalizedPreference = validThemes.has(preference) ? preference : 'system';
    const resolvedTheme = resolveTheme(normalizedPreference);
    document.documentElement.dataset.theme = resolvedTheme;
    document.documentElement.dataset.themePreference = normalizedPreference;
    document.documentElement.style.colorScheme = resolvedTheme;

    if (themeMeta) {
      themeMeta.setAttribute('content', resolvedTheme === 'dark' ? '#15171c' : '#ffffff');
    }

    if (typeof window.__setSiteTheme === 'function') {
      window.__setSiteTheme(normalizedPreference);
    }

    syncThemeButtons(normalizedPreference);
  };

  themeButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const nextPreference = button.dataset.themeOption || 'system';
      try {
        window.localStorage.setItem(themeStorageKey, nextPreference);
      } catch {
        // Ignore storage failures and keep the in-memory theme change.
      }
      applyThemePreference(nextPreference);
    });
  });

  applyThemePreference(getThemePreference());

  themeMedia.addEventListener('change', () => {
    if (getThemePreference() === 'system') {
      applyThemePreference('system');
    }
  });
</script>
