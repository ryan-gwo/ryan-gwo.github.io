---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import InstitutionLogo from '../../components/InstitutionLogo.astro';

const writingModules = import.meta.glob('./writing/*.md', { eager: true });
const selectedWriting = Object.values(writingModules)
  .map((entry) => ({
    frontmatter: entry.frontmatter ?? entry.default?.frontmatter ?? {},
    url: entry.url ?? entry.default?.url ?? '',
  }))
  .filter((entry) => entry.frontmatter?.featured && entry.url)
  .sort((a, b) => (a.frontmatter?.priority ?? 999) - (b.frontmatter?.priority ?? 999))
  .slice(0, 3);
---

<BaseLayout
  title="Yuze Guo"
  description="Yuze Guo 的个人网站"
  locale="zh-cn"
>
  <section id="overview" class="section-dark hero">
    <div class="container">
      <p class="eyebrow">学术个人主页</p>
      <h1 class="hero-name">郭雨泽</h1>
      <p class="hero-identity">武汉大学物理学本科生</p>
      <p class="hero-focus">研究方向：引力波、宇宙学、多信使天文学</p>
      <p class="lead">我关注如何从观测信号中提取并解释宇宙的物理信息。</p>
      <div class="actions">
        <a class="button button-primary" href="/zh-cn/research/"><Icon name="info.circle" />了解研究</a>
        <a class="button button-secondary" href="/zh-cn/writings/">阅读写作</a>
      </div>
    </div>
  </section>

  <section id="research" class="section-light content-section featured-research">
    <div class="container">
      <h2 class="section-title">研究</h2>
      <p class="section-intro light">当前工作围绕从观测中提取可检验的物理约束，主要在三个相互关联的方向展开。</p>
      <div class="grid">
        <div class="card">
          <h3>引力波</h3>
          <p>研究来自致密天体系统的长时程引力波信号，重点是连续引力波搜寻、弱信号表征以及边缘候选体的天体物理解读。</p>
        </div>
        <div class="card">
          <h3>宇宙学</h3>
          <p>关注相对论时空与早期宇宙假设如何传递到参数推断，尤其是理论与观测耦合仍较弱的情形。</p>
        </div>
        <div class="card">
          <h3>多信使天文学</h3>
          <p>通过联合分析引力与电磁观测，构建物理一致的源模型，并缓解单一通道中常见的参数退化。</p>
        </div>
      </div>
      <div class="actions">
        <a class="button button-link" href="/zh-cn/research/">查看完整研究页面</a>
      </div>
    </div>
  </section>

  <section id="writing" class="section-dark content-section selected-writing">
    <div class="container">
      <h2 class="section-title">精选写作</h2>
      <p class="section-intro light">挑选最能体现我思考方式与兴趣结构的写作，而非按时间堆叠的内容列表。</p>
      {selectedWriting.length > 0 ? (
        <div class="selected-writing-list">
          {selectedWriting.map(({ frontmatter, url }) => (
            <article class="article-card">
              <div class="article-meta">{frontmatter.dateText}</div>
              <h3>{frontmatter.title}</h3>
              <p>{frontmatter.summary ?? frontmatter.description}</p>
            </article>
          ))}
        </div>
      ) : null}
      <div class="selected-writing-actions">
        <a class="button button-link" href="/zh-cn/writings/">查看全部写作</a>
      </div>
    </div>
  </section>

  <section id="now" class="section-light content-section now-section">
    <div class="container">
      <h2 class="section-title">现在在做什么</h2>
      <p class="section-intro">这里记录我当前稳定推进的重点，会随阶段变化调整，但不作为动态消息流。</p>
      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-tag">近期研究主题</div>
          <div class="timeline-text">围绕引力波数据分析做博士前准备，重点放在连续引力波搜寻流程与候选体物理解释。</div>
        </div>
        <div class="timeline-item">
          <div class="timeline-tag">学习重点</div>
          <div class="timeline-text">持续补强统计推断、信号处理与计算工作流，作为宇宙学和多信使研究的基础工具。</div>
        </div>
        <div class="timeline-item">
          <div class="timeline-tag">写作计划</div>
          <div class="timeline-text">先用短笔记整理课程与文献中的核心问题，再把成熟主题扩展成更完整的文章。</div>
        </div>
        <div class="timeline-item">
          <div class="timeline-tag">申请阶段状态</div>
          <div class="timeline-text">按阶段整理申请材料，包括研究陈述、推荐信协同与项目经历归纳。</div>
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="section-dark content-section content-section-spacious brief-about">
    <div class="container">
      <h2 class="section-title">简介</h2>
      <div class="about-shell">
        <div class="profile-card">
          <img src="/images/prof_pic.jpg" alt="郭雨泽个人照片" />
          <div class="profile-caption">2023年摄于牛津大学贝利奥尔学院。</div>
        </div>

        <div class="about-copy">
          <p>
            嗨！我是郭雨泽，目前是<InstitutionLogo institution="whu">武汉大学</InstitutionLogo>物理科学与技术学院的一名物理学专业本科生。
          </p>
          <p>
            我预计在 2026 年秋开始在<InstitutionLogo institution="pku">北京大学</InstitutionLogo>物理学院天文学系攻读天体物理博士。
            长期研究兴趣集中在高能天体物理，尤其是引力波、宇宙学和多信使天文学。
          </p>
          <p>
            在此之前，我作为物理竞赛组的一员，在<InstitutionLogo institution="hsfz">华南师范大学附属中学</InstitutionLogo>完成中学阶段学习，并通过华附天文社（HFAA）系统接触天文学。
          </p>
          <div class="about-brief-actions">
            <a class="button button-primary" href="/zh-cn/cv/" rel="noreferrer">查看简历</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="life" class="section-light content-section life-glimpses">
    <div class="container">
      <h2 class="section-title">研究之外</h2>
      <p class="section-intro">几段低饱和的日常，不展开，只作为主线旁的轻微留白。</p>
      <div class="grid">
        <div class="card">
          <h3>观星夜晚</h3>
          <p>天气允许时会做一些轻量观测，保留简短记录，维持与天空的长期连接。</p>
        </div>
        <div class="card">
          <h3>阅读片刻</h3>
          <p>常读科学史与人物传记，慢节奏阅读经常反过来帮助我组织研究问题。</p>
        </div>
        <div class="card">
          <h3>行走与摄影</h3>
          <p>校园散步与偶尔旅行时会拍一些照片，用细节感受来平衡高强度的思考。</p>
        </div>
      </div>
    </div>
  </section>

  <section id="contact" class="section-dark content-section content-section-spacious contact-section">
    <div class="container contact-box">
      <h2 class="section-title">联系</h2>
      <p>学术沟通建议优先通过邮箱联系。</p>
      <p>
        <a class="contact-primary" href="mailto:guoyuze@whu.edu.cn">guoyuze@whu.edu.cn</a>
      </p>
      <p class="contact-secondary-links">
        <a href="https://github.com/ryan-gwo" target="_blank" rel="noreferrer">GitHub 主页</a>
        <span aria-hidden="true"> · </span>
        <a href="/zh-cn/resources/" rel="noreferrer"><Icon name="download" />研究资料与下载</a>
      </p>
    </div>
  </section>
</BaseLayout>